            "type": "string",
            "enum": [
                "SMS",
                "WHATSAPP",
                "ALL"
            ]
        },
        "signature_type": {
            "type": "string",
            "enum": [
                "dsc",
                "aadhaar",
                "external",
                "external_sign",
                "aadhaar_with_dependents",
                "electronic_with_dependents",
                "electronic",
                "document_review"
            ]
        },
        "estamp_request": {
            "type": "object",
            "properties": {
                "tags": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer"
                    }
                },
                "note_content": {
                    "type": "string"
                },
                "note_on_page": {
                    "type": "string",
                    "enum": [
                        "first",
                        "last",
                        "all",
                        "custom"
                    ]
                },
                "sign_on_page": {
                    "type": "string",
                    "enum": [
                        "first",
                        "last",
                        "all",
                        "custom"
                    ]
                }
            }
        },
        "generate_access_token": {
            "type": "boolean"
