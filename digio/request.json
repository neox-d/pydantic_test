    "properties": {
        "file_name": {
            "type": "string"
        },
        "will_self_sign": {
            "type": "boolean"
        },
        "signatory": {
            "type": "string"
        },
        "expire_in_days": {
            "type": "integer"
        },
        "callback": {
            "type": "string"
        },
        "comment": {
            "type": "string"
        },
        "display_on_page": {
            "type": "string",
            "enum": [
                "first",
                "last",
                "all",
                "custom"
            ]
        },
        "sign_coordinates": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "llx": {
                                "type": "integer"
                            },
                            "lly": {
                                "type": "integer"
                            },
                            "urx": {
                                "type": "integer"
                            },
                            "ury": {
                                "type": "integer"
                            }
                        },
                        "required": [
                            "llx",
                            "lly",
                            "urx",
                            "ury"
                        ]
                    }
                }
            }
        },
        "notify_signers": {
            "type": "boolean"
