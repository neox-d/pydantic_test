                    "type": "object",
                    "properties": {
                        "pageMetaData": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "object",
                                "properties": {
                                    "width": {
                                        "type": "number"
                                    },
                                    "height": {
                                        "type": "number"
                                    }
                                }
                            }
                        }
                    }
                },
                "consents": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    },
    "$defs": {
        "signature_verification_response": {
            "type": "object",
            "properties": {
                "overallResult": {
                    "type": "string"
                },
                "ruleResults": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "ruleId": {
                                "type": "integer"
                            },
                            "result": {
                                "type": "string"
                            },
                            "operation": {
                                "type": "string",
                                "enum": [
                                    "AND",
                                    "OR"
                                ]
                            },
                            "conditions": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "field": {
                                            "type": "string"
                                        },
                                        "match": {
                                            "type": "string"
                                        },
                                        "actualValue": {
                                            "type": "string"
                                        },
                                        "expectedValue": {
                                            "type": "string"
                                        },
                                        "fuzzyScore": {
                                            "type": "integer"
                                        },
                                        "result": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "signing_feature": {
            "type": "object",
            "properties": {
                "featureId": {
                    "type": "string"
                },
                "result": {
                    "type": "string"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "geo_location",
                        "consent"
                    ]
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "requested",
                        "success",
                        "skipped"
                    ]
                },
                "optional": {
                    "type": "boolean"
                },
                "performEnrichment": {
                    "type": "boolean"
                },
                "seed_method": {
                    "type": "string",
                    "enum": [
                        "seeding",
                        "user_input"
                    ]
                },
                "seeding_required": {
                    "type": "boolean"
                },
                "existing_user_name": {
                    "type": "string"
                }
            }
        },
        "draft_signer": {
            "type": "object",
            "properties": {
                "signer": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "identifier": {
                            "type": "string"
                        },
                        "reminder": {
                            "type": "array",
                            "items": {
                                "type": "integer"
                            }
                        },
                        "signType": {
                            "type": "string",
                            "enum": [
                                "dsc",
                                "aadhaar",
                                "external",
                                "external_sign",
                                "aadhaar_with_dependents",
                                "electronic_with_dependents",
                                "electronic",
                                "document_review"
                            ]
                        },
                        "signatureMode": {
                            "type": "string",
                            "enum": [
                                "otp",
                                "slate",
                                "kyc",
                                "otp_certified",
                                "slate_certified",
                                "esign_3",
                                "esign_3s",
                                "nesl_aadhaar_sign"
                            ]
                        },
                        "optional": {
                            "type": "boolean"
                        },
                        "signing_addons": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": [
                                            "geo_location",
                                            "consent"
                                        ]
                                    },
                                    "performEnrichment": {
                                        "type": "boolean"
                                    },
                                    "optional": {
                                        "type": "boolean"
                                    }
                                },
                                "required": [
                                    "type"
                                ]
                            }
                        },
                        "expiredInDays": {
                            "type": "integer"
                        },
                        "preferredSeedMethod": {
                            "type": "string",
                            "enum": [
                                "seeding",
                                "user_input"
                            ]
                        },
                        "coords": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "llx": {
                                            "type": "integer"
                                        },
                                        "lly": {
                                            "type": "integer"
                                        },
                                        "urx": {
                                            "type": "integer"
                                        },
                                        "ury": {
                                            "type": "integer"
                                        }
                                    },
                                    "required": [
                                        "llx",
                                        "lly",
                                        "urx",
                                        "ury"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "estamp_request": {
            "type": "object",
            "properties": {
                "tags": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer"
                    }
                },
                "note_content": {
                    "type": "string"
                },
                "note_on_page": {
                    "type": "string",
                    "enum": [
                        "first",
                        "last",
                        "all",
                        "custom"
                    ]
                },
                "sign_on_page": {
                    "type": "string",
                    "enum": [
                        "first",
                        "last",
                        "all",
                        "custom"
                    ]
                }
            }
        },
        "signature_verification": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "abortOnFail": {
                        "type": "boolean"
                    },
                    "maxAttempt": {
                        "type": "integer"
                    },
                    "rules": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "operation": {
                                    "type": "string",
                                    "enum": [
                                        "AND",
                                        "OR"
                                    ]
                                },
                                "conditions": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "field": {
                                                "type": "string",
                                                "enum": [
                                                    "NAME",
                                                    "YOB",
                                                    "AADHAAR",
                                                    "GENDER"
                                                ]
                                            },
                                            "matchType": {
                                                "type": "string",
                                                "enum": [
                                                    "EXACT",
                                                    "FUZZY"
                                                ]
                                            },
                                            "value": {
                                                "type": "string"
                                            },
                                            "threshold": {
                                                "type": "integer"
                                            },
                                            "inputValue": {
                                                "type": "string"
                                            },
                                            "fuzzyScore": {
                                                "type": "integer"
                                            },
                                            "multiPropertyRule": {
                                                "type": "object",
                                                "additionalProperties": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string"
                                                    }
                                                }
                                            }
                                        },
                                        "required": [
                                            "field",
                                            "matchType",
                                            "value"
                                        ]
                                    }
                                }
                            },
                            "required": [
                                "operation",
                                "conditions"
                            ]
                        }
                    }
                },
                "required": [
                    "abortOnFail",
                    "maxAttempt",
                    "rules"
                ]
            }
        },
        "signing_condition_request": {
            "type": "object",
            "properties": {
                "conditions": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "signingCondition": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "type": {
                                            "type": "string",
                                            "enum": [
                                                "AT_LEAST_N_ACTIONERS",
                                                "REQUIRED_UNITS"
                                            ]
                                        },
                                        "signers": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "signingPartyId": {
                                                        "type": "string"
                                                    },
                                                    "identifier": {
                                                        "type": "string"
                                                    },
                                                    "name": {
                                                        "type": "string"
                                                    },
                                                    "signingStatus": {
                                                        "type": "string"
                                                    },
                                                    "signedAt": {
                                                        "type": "string"
                                                    }
                                                }
                                            }
                                        },
                                        "identifiers": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            }
                                        },
                                        "value": {
                                            "type": "integer"
                                        },
                                        "conditionPassed": {
                                            "type": "boolean"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}